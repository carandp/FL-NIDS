{
  "format_version": 2,
  "executors": [
    {
      "tasks": ["train"],
      "executor": {
        "path": "nids_trainer.NIDSTrainer",
        "args": {
          "data_dir": "/home/<username>/FL-NIDS/datasets/fed_clients/{SITE_NAME}",
          "local_epochs": 2,
          "batch_size": 16384,
          "ae_batch_size": 64,
          "window_size": 512,
          "step_percent": 1.0,
          "fanout": 32768,
          "learning_rate": 0.0001,
          "weight_decay": 0.6,
          "ae_weight_decay": 0.03986574357073468,
          "edim_out": 64,
          "embed_dim": 32,
          "num_heads": 4,
          "num_layers": 1,
          "dropout": 0.5,
          "ae_dropout": 0.2,
          "agg_type": "mean",
          "mask_ratio": 0.15,
          "positional_encoding": null,
          "client_id": "{SITE_NAME}"
        }
      }
    }
  ],
  "task_data_filters": [
    {
      "tasks": ["train"],
      "filters": [
        {
          "path": "nvflare.app_opt.he.model_decryptor.HEModelDecryptor",
          "args": {}
        }
      ]
    }
  ],
  "task_result_filters": [
    {
      "tasks": ["train"],
      "filters": [
        {
          "path": "nvflare.app_opt.he.model_encryptor.HEModelEncryptor",
          "args": {
            "weigh_by_local_iter": true
          }
        }
      ]
    }
  ]
}