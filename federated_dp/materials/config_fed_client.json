{
  "_comment": "config_fed_client.json – PASTE into each client's config/. Change dataset_size per client!",
  "format_version": 2,

  "executors": [
    {
      "tasks": ["train"],
      "executor": {
        "id": "Executor",
        "path": "nvflare.app_common.executors.learner_executor.LearnerExecutor",
        "args": {
          "learner_id": "my_learner"
        }
      }
    }
  ],

  "components": [
    {
      "id": "my_learner",
      "path": "my_project.learner.MyLearner",
      "args": {}
    },

    {
      "_comment": "── DP filter: add this to task_result_filters ──",
      "id": "dp_gaussian_filter",
      "path": "dp_gaussian_filter.DPGaussianFilter",
      "args": {
        "_comment_dataset_size": "SET THIS PER CLIENT: 770415 / 1394658 / 10960",
        "dataset_size":     770415,
        "batch_size":       32,
        "local_epochs":     2,

        "_comment_clip":    "L2 clip bound C — run dp_noise_calibrator.py first",
        "clip_norm":        1.0,

        "_comment_sigma":   "noise_multiplier σ — output of dp_noise_calibrator.py",
        "noise_multiplier": 1.30,

        "_comment_budget":  "per-client privacy budget target",
        "target_epsilon":   10.0,
        "target_delta":     1e-5,

        "_comment_dir":     "where to persist budget JSON between rounds",
        "budget_dir":       "/tmp/nvflare_dp_budget"
      }
    }
  ],

  "task_result_filters": [
    {
      "tasks": ["train"],
      "filters": ["dp_gaussian_filter"]
    }
  ],

  "task_data_filters": []
}
